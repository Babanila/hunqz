{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "strict": true,
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "paths": {
      "@repo/shared-data/*": [
        "../../packages/shared-data/src/*"
      ],
      "@repo/ui/*": [
        "../../packages/ui/src/*"
      ]
    }
  }
}
